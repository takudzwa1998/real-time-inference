# ── Docker ───────────────────────────────────────────────
# Don't ignore docker-compose.override.yml — it's part of the dev workflow

# ── Model weights (large binary files — do not commit) ───
# Stored in weights/ and bind-mounted into Docker.
# Download once with: docker compose run --rm inference python -c "from model_registry import ensure_weights; ensure_weights('yolox-nano', '/model-weights')"
# Or just start the stack — weights auto-download on first inference startup.
weights/*.pth
weights/*.pt
weights/*.onnx
weights/*.engine

# ── macOS ────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDE ───────────────────────────────────────────────────
.idea/
*.iml
.vscode/settings.json

# ── Logs ─────────────────────────────────────────────────
*.log
logs/

# ── Misc ─────────────────────────────────────────────────
*.bak
*.swp
