{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Real-Time Inference Platform — operations dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Service Health",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red",   "text": "DOWN" },
                           "1": { "color": "green", "text": "UP"   } },
              "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",   "value": null },
            { "color": "green", "value": 1 }
          ]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "horizontal",
                   "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"inference\"}",
          "legendFormat": "inference", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"consumer\"}",
          "legendFormat": "consumer", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"api\"}",
          "legendFormat": "api", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"rabbitmq\"}",
          "legendFormat": "rabbitmq", "refId": "D" }
      ],
      "title": "Service Status",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "id": 101,
      "title": "Camera Metrics",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "fps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "camera_fps",
          "legendFormat": "{{camera_id}}", "refId": "A" }
      ],
      "title": "FPS per Camera",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "inference_queue_depth",
          "legendFormat": "{{camera_id}}", "refId": "A" }
      ],
      "title": "Queue Depth per Camera",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 102,
      "title": "Inference Performance",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "p95"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(inference_latency_seconds_bucket[1m])) by (le, camera_id, model))",
          "legendFormat": "p50 {{camera_id}} {{model}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(inference_latency_seconds_bucket[1m])) by (le, camera_id, model))",
          "legendFormat": "p95 {{camera_id}} {{model}}", "refId": "B" }
      ],
      "title": "Inference Latency p50 / p95",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(frames_dropped_total[1m])) by (camera_id, reason)",
          "legendFormat": "{{camera_id}} ({{reason}})", "refId": "A" }
      ],
      "title": "Frame Drop Rate",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 103,
      "title": "Detections",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 6,
      "options": {
        "barWidth": 0.6,
        "xTickLabelRotation": -30
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, sum(increase(detections_total[1h])) by (class))",
          "legendFormat": "{{class}}", "refId": "A" }
      ],
      "title": "Detections by Class (last 1 h)",
      "type": "barchart"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(detections_total[1m])) by (camera_id)",
          "legendFormat": "{{camera_id}}", "refId": "A" }
      ],
      "title": "Detections Rate per Camera",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 104,
      "title": "RabbitMQ",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 8,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_queue_messages{queue=~\"detections.*\"}",
          "legendFormat": "{{queue}}", "refId": "A" }
      ],
      "title": "RabbitMQ Queue Depth",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 9,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(rabbitmq_publish_errors_total[1m]))",
          "legendFormat": "publish errors/s", "refId": "A" }
      ],
      "title": "RabbitMQ Publish Errors",
      "type": "timeseries"
    }

  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["inference", "cv", "iot"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Real-Time Inference Platform",
  "uid": "real-time-inference",
  "version": 1
}
