# ─────────────────────────────────────────────────────────
# Real-Time Inference Platform — Environment Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is git-ignored. Never commit secrets.
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=inference
POSTGRES_PASSWORD=inference
POSTGRES_DB=inference
POSTGRES_PORT=5432          # host port (override only)

# ── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_AMQP_PORT=5672     # host port (override only)
RABBITMQ_MGMT_PORT=15672    # host port (override only)

# ── Inference Service ────────────────────────────────────
# Comma-separated list of stream sources.
# Formats: rtsp://<user>:<pass>@<host>/stream  |  webcam:<index>  |  file:/path/to/clip.mp4
CAMERAS=webcam:0

# YOLOX model variant (Apache 2.0 — Megvii).
# Weights are auto-downloaded to /model-weights on first startup.
# Ordered lightest → heaviest: nano (0.9M) | tiny (5M) | s (9M) | m (25M) | l (54M) | x (99M)
YOLOX_MODEL=yolox-nano

# Inference confidence / NMS thresholds
CONF_THRESHOLD=0.25
NMS_THRESHOLD=0.45

# Bounded queue settings per camera
QUEUE_MAX_SIZE=30
# oldest = drop oldest frame on full queue; newest = skip incoming frame
DROP_POLICY=oldest

# Number of parallel YOLO worker threads
INFERENCE_WORKERS=2

# Run inference on every Kth frame (1 = every frame, 3 = every 3rd)
SAMPLE_EVERY_K=1

INFERENCE_PORT=8001         # host port (override only)

# ── Consumer Service ─────────────────────────────────────
# Suppress repeat alerts for the same rule+camera for N seconds
DEBOUNCE_SECONDS=60

CONSUMER_PORT=8002          # host port (override only)

# ── API Gateway ──────────────────────────────────────────
API_PORT=8000               # host port (override only)

# Stub API key for future auth (not enforced in v1)
API_KEY=changeme

# ── Frontend ─────────────────────────────────────────────
FRONTEND_PORT=3000

# ── RabbitMQ message topology ────────────────────────────
DETECTIONS_EXCHANGE=detections

# ── Telegram Alerts (optional) ───────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Webhook Alerts (optional) ────────────────────────────
WEBHOOK_URL=
# Exponential backoff: base delay seconds between retries
WEBHOOK_RETRY_BACKOFF=1

# ── Observability ────────────────────────────────────────
PROMETHEUS_PORT=9090        # host port (override only)
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Logging ──────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
